# Copy to `.env` (gitignored) and fill in. Loaded by Arioso.train at startup.
# Get your key from https://wandb.ai/authorize
WANDB_API_KEY=

# Defeats GPU memory fragmentation from variable-length (length-bucketed) batches.
# Must be set before CUDA initializes; train.py loads .env at the top of main().
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
